rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return signedIn() ? request.auth.token.email : null;
    }

    function authUid() {
      return signedIn() ? request.auth.uid : null;
    }

    function isSelf(idValue) {
      return signedIn() && (idValue == authUid() || idValue == authEmail());
    }

function isAdmin() {
return signedIn() && authEmail() in [
  'ozenenesis56@gmail.com',
  'u8075026427@gmail.com'
];
}

    function isProtectedAdFieldChanged() {
      return request.resource.data.pinType != resource.data.pinType ||
             request.resource.data.pinnedAt != resource.data.pinnedAt ||
             request.resource.data.pinnedUntil != resource.data.pinnedUntil ||
             request.resource.data.pinQueueAt != resource.data.pinQueueAt ||
             request.resource.data.bumpAt != resource.data.bumpAt ||
             request.resource.data.highlightType != resource.data.highlightType ||
             request.resource.data.highlightUntil != resource.data.highlightUntil ||
             request.resource.data.paidAt != resource.data.paidAt ||
             request.resource.data.paymentId != resource.data.paymentId ||
             request.resource.data.status != resource.data.status;
    }

    function isProtectedAuctionFieldChanged() {
      return request.resource.data.promotionType != resource.data.promotionType ||
             request.resource.data.promotionUntil != resource.data.promotionUntil ||
             request.resource.data.promotionQueueAt != resource.data.promotionQueueAt ||
             request.resource.data.status != resource.data.status;
    }

    function isUserSoftDeletingAd() {
      return isSelf(resource.data.userId) &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'status',
               'deletedAt',
               'deletedBy',
               'deleteReason'
             ]) &&
             request.resource.data.status == 'deleted' &&
             request.resource.data.deletedAt is number &&
             isSelf(request.resource.data.deletedBy) &&
             request.resource.data.deleteReason == 'user_deleted';
    }

    function isUserSoftDeletingAuction() {
      return isSelf(resource.data.ownerId) &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'status',
               'deletedAt',
               'deletedBy',
               'deleteReason'
             ]) &&
             request.resource.data.status == 'deleted' &&
             request.resource.data.deletedAt is number &&
             isSelf(request.resource.data.deletedBy) &&
             request.resource.data.deleteReason == 'user_deleted';
    }

    function isValidAuctionBidUpdate() {
      return resource.data.status == 'active' &&
             resource.data.endsAt is number &&
             resource.data.endsAt > request.time.toMillis() &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'currentBid',
               'currentBidderId',
               'currentBidderName',
               'bidsCount'
             ]) &&
             resource.data.currentBid is number &&
             request.resource.data.currentBid is number &&
             request.resource.data.currentBid > resource.data.currentBid &&
             resource.data.bidsCount is number &&
             request.resource.data.bidsCount == resource.data.bidsCount + 1 &&
             request.resource.data.currentBidderId is string &&
             isSelf(request.resource.data.currentBidderId) &&
             !isSelf(resource.data.ownerId) &&
             request.resource.data.currentBidderName is string &&
             request.resource.data.currentBidderName.size() > 0 &&
             request.resource.data.currentBidderName.size() <= 80;
    }

    function isValidAuctionBidCreate(auctionId) {
      let auction = get(/databases/$(database)/documents/auctions/$(auctionId)).data;
      return request.resource.data.keys().hasOnly([
               'auctionId',
               'userId',
               'userName',
               'amount',
               'createdAt'
             ]) &&
             request.resource.data.auctionId == auctionId &&
             request.resource.data.userId is string &&
             isSelf(request.resource.data.userId) &&
             request.resource.data.userName is string &&
             request.resource.data.userName.size() > 0 &&
             request.resource.data.userName.size() <= 80 &&
             request.resource.data.amount is number &&
             request.resource.data.createdAt is number &&
             auction.status == 'active' &&
             auction.endsAt is number &&
             auction.endsAt > request.time.toMillis() &&
             auction.currentBid is number &&
             request.resource.data.amount > auction.currentBid &&
             !isSelf(auction.ownerId);
    }

    function hasProtectedAdCreateFields() {
      return request.resource.data.keys().hasAny([
        'pinType',
        'pinnedAt',
        'pinnedUntil',
        'pinQueueAt',
        'bumpAt',
        'highlightType',
        'highlightUntil',
        'paidAt',
        'paymentId'
      ]);
    }

    function hasPaidAuctionCreateFields() {
      return ('promotionType' in request.resource.data && request.resource.data.promotionType != 'none') ||
             ('promotionUntil' in request.resource.data && request.resource.data.promotionUntil != null) ||
             ('promotionQueueAt' in request.resource.data && request.resource.data.promotionQueueAt != null);
    }

    match /users/{userId} {
       // Нужен публичный read для проверки занятых никнеймов при регистрации
            // и отображения никнеймов в чатах/карточках.
            allow read: if true;
            allow create, update, delete: if isSelf(userId);
    }

    match /ads/{adId} {
      allow read: if true;
      allow create: if signedIn() &&
        isSelf(request.resource.data.userId) &&
        !hasProtectedAdCreateFields();
      allow update: if signedIn() && (
        (isSelf(resource.data.userId) && (!isProtectedAdFieldChanged() || isUserSoftDeletingAd())) ||
        isAdmin()
      );
      allow delete: if false;
    }

    match /auctions/{auctionId} {
      allow read: if true;
      allow create: if signedIn() &&
        isSelf(request.resource.data.ownerId) &&
        !hasPaidAuctionCreateFields();
      allow update: if signedIn() && (
        (isSelf(resource.data.ownerId) && (!isProtectedAuctionFieldChanged() || isUserSoftDeletingAuction())) ||
        isValidAuctionBidUpdate() ||
        isAdmin()
      );
      allow delete: if false;
    }

    match /auctionBids/{auctionId}/bids/{bidId} {
      allow read: if true;
      allow create: if signedIn() && isValidAuctionBidCreate(auctionId);
      allow update, delete: if false;
    }

    match /chats/{chatId} {
      allow read, update: if signedIn() && (
        authUid() in resource.data.users || authEmail() in resource.data.users
      );
      allow create: if signedIn() && (
        authUid() in request.resource.data.users || authEmail() in request.resource.data.users
      );

      match /messages/{messageId} {
        allow read, create: if signedIn() && (
          authUid() in get(/databases/$(database)/documents/chats/$(chatId)).data.users ||
          authEmail() in get(/databases/$(database)/documents/chats/$(chatId)).data.users
        );
        allow update, delete: if false;
      }
    }

match /reports/{reportId} {
allow create: if signedIn() &&
  request.resource.data.keys().hasOnly([
    'targetType',
    'targetId',
    'reporterId',
    'reason',
    'description',
    'status',
    'createdAt',
    'reviewedAt',
    'reviewedBy'
  ]) &&
  request.resource.data.targetType in ['ad', 'auction'] &&
  request.resource.data.targetId is string &&
  request.resource.data.reporterId == authUid() &&
  request.resource.data.reason is string &&
  request.resource.data.description is string &&
  request.resource.data.status == 'new' &&
  request.resource.data.createdAt is number &&
  request.resource.data.reviewedAt == null &&
  request.resource.data.reviewedBy == null;
allow read, update, delete: if isAdmin();
}
match /userReviews/{reviewId} {
allow read: if true;
allow create: if signedIn() &&
    isSelf(request.resource.data.authorUserId) &&
    request.resource.data.targetUserId != request.resource.data.authorUserId &&
request.resource.data.karmaValue in [-1, 1] &&
(!("comment" in request.resource.data) || request.resource.data.comment is string);
allow update: if signedIn() && isSelf(resource.data.authorUserId) &&
    request.resource.data.authorUserId == resource.data.authorUserId &&
    request.resource.data.targetUserId == resource.data.targetUserId &&
request.resource.data.adId == resource.data.adId &&
request.resource.data.karmaValue in [-1, 1] &&
(!("comment" in request.resource.data) || request.resource.data.comment is string);
allow delete: if isAdmin();
}

    match /payments/{paymentId} {
      allow read: if signedIn() && (
        isSelf(resource.data.userId) ||
        isSelf(resource.data.userEmail) ||
         isSelf(resource.data.payerEmail) ||
        isAdmin()
      );
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
