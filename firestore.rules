rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return signedIn() ? request.auth.token.email : null;
    }

    function authUid() {
      return signedIn() ? request.auth.uid : null;
    }

    function isSelf(idValue) {
      return signedIn() && (idValue == authUid() || idValue == authEmail());
    }

    function isOwnUserDoc(userId) {
      return signedIn() &&
             authEmail() != null &&
             userId == authEmail();
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(authEmail());
    }

    function isBlockedUser() {
      return signedIn() &&
             authEmail() != null &&
             exists(userDocPath()) &&
             ('status' in get(userDocPath()).data) &&
             get(userDocPath()).data.status == 'blocked';
    }

    function canUseAccount() {
      return signedIn() && !isBlockedUser();
    }

function isAdmin() {
return signedIn() && authEmail() in [
  'ozenenesis56@gmail.com',
  'u8075026427@gmail.com'
];
}

function isProtectedAdFieldChanged() {
return request.resource.data.diff(resource.data).affectedKeys().hasAny([
    'pinType',
    'pinnedAt',
    'pinnedUntil',
    'pinQueueAt',
    'bumpAt',
    'highlightType',
    'highlightUntil',
    'paidAt',
    'paymentId',
    'status',
    'adminViewedAt',
    'adminViewedBy'
]);
}

    function isProtectedAuctionFieldChanged() {
      return request.resource.data.promotionType != resource.data.promotionType ||
             request.resource.data.promotionUntil != resource.data.promotionUntil ||
             request.resource.data.promotionQueueAt != resource.data.promotionQueueAt ||
             request.resource.data.status != resource.data.status;
    }

    function isUserSoftDeletingAd() {
      return isSelf(resource.data.userId) &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'status',
               'deletedAt',
               'deletedBy',
               'deleteReason'
             ]) &&
             request.resource.data.status == 'deleted' &&
             request.resource.data.deletedAt is number &&
             isSelf(request.resource.data.deletedBy) &&
             request.resource.data.deleteReason == 'user_deleted';
    }

    function isUserSoftDeletingAuction() {
      return isSelf(resource.data.ownerId) &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'status',
               'deletedAt',
               'deletedBy',
               'deleteReason'
             ]) &&
             request.resource.data.status == 'deleted' &&
             request.resource.data.deletedAt is number &&
             isSelf(request.resource.data.deletedBy) &&
             request.resource.data.deleteReason == 'user_deleted';
    }

    function isValidAuctionBidUpdate() {
      return canUseAccount() &&
             resource.data.status == 'active' &&
             resource.data.endsAt is number &&
             resource.data.endsAt > request.time.toMillis() &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'currentBid',
               'currentBidderId',
               'currentBidderName',
               'bidsCount'
             ]) &&
             resource.data.currentBid is number &&
             request.resource.data.currentBid is number &&
             request.resource.data.currentBid > resource.data.currentBid &&
             resource.data.bidsCount is number &&
             request.resource.data.bidsCount == resource.data.bidsCount + 1 &&
             request.resource.data.currentBidderId is string &&
             isSelf(request.resource.data.currentBidderId) &&
             !isSelf(resource.data.ownerId) &&
             request.resource.data.currentBidderName is string &&
             request.resource.data.currentBidderName.size() > 0 &&
             request.resource.data.currentBidderName.size() <= 80;
    }

    function isValidAuctionBidCreate(auctionId) {
      let auction = get(/databases/$(database)/documents/auctions/$(auctionId)).data;
      return request.resource.data.keys().hasOnly([
               'auctionId',
               'userId',
               'userName',
               'amount',
               'createdAt'
             ]) &&
             request.resource.data.auctionId == auctionId &&
             request.resource.data.userId is string &&
             isSelf(request.resource.data.userId) &&
             request.resource.data.userName is string &&
             request.resource.data.userName.size() > 0 &&
             request.resource.data.userName.size() <= 80 &&
             request.resource.data.amount is number &&
             request.resource.data.createdAt is number &&
             auction.status == 'active' &&
             auction.endsAt is number &&
             auction.endsAt > request.time.toMillis() &&
             auction.currentBid is number &&
             request.resource.data.amount > auction.currentBid &&
             !isSelf(auction.ownerId);
    }

    function hasProtectedAdCreateFields() {
      return request.resource.data.keys().hasAny([
        'pinType',
        'pinnedAt',
        'pinnedUntil',
        'pinQueueAt',
        'bumpAt',
        'highlightType',
        'highlightUntil',
        'paidAt',
        'paymentId',
        'adminViewedAt',
        'adminViewedBy'
      ]);
    }

    function hasPaidAuctionCreateFields() {
      return ('promotionType' in request.resource.data && request.resource.data.promotionType != 'none') ||
             ('promotionUntil' in request.resource.data && request.resource.data.promotionUntil != null) ||
             ('promotionQueueAt' in request.resource.data && request.resource.data.promotionQueueAt != null);
    }

    // TODO: Next security phase: create sanitized publicAds/publicAuctions because Firestore rules cannot hide fields inside public documents.
    function isPublicAdRead() {
      return resource.data.status == 'active';
    }

    function isPublicAuctionRead() {
      return resource.data.status == 'active';
    }

    function isValidOwnUserCreate(userId) {
      return isOwnUserDoc(userId) &&
             request.resource.data.keys().hasOnly([
               'id',
               'uid',
               'email',
               'nickname',
               'status',
               'karma',
               'createdAt',
               'phone',
               'telegram'
             ]) &&
             request.resource.data.id == userId &&
             request.resource.data.uid == authUid() &&
             request.resource.data.email == authEmail() &&
             request.resource.data.nickname is string &&
             request.resource.data.nickname.size() > 0 &&
             request.resource.data.nickname.size() <= 80 &&
             request.resource.data.status == 'active' &&
             request.resource.data.karma == 0 &&
             request.resource.data.createdAt is number;
    }

    function isValidOwnUserUpdate(userId) {
      return isOwnUserDoc(userId) &&
             request.resource.data.uid == authUid() &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'nickname',
               'phone',
               'telegram',
               'updatedAt'
             ]) &&
             (!('nickname' in request.resource.data) || (
               request.resource.data.nickname is string &&
               request.resource.data.nickname.size() > 0 &&
               request.resource.data.nickname.size() <= 80
             ));
    }

    function isValidNicknameReservation() {
      return signedIn() &&
             request.resource.data.keys().hasOnly([
               'nickname',
               'createdAt'
             ]) &&
             request.resource.data.nickname is string &&
             request.resource.data.nickname.size() > 0 &&
             request.resource.data.nickname.size() <= 80 &&
             request.resource.data.createdAt is number;
    }

    match /users/{userId} {
            // Full user profiles are private: only admins and the owner can read them.
            allow get: if isAdmin() || isOwnUserDoc(userId);
            allow list: if isAdmin();
            allow create: if isAdmin() || isValidOwnUserCreate(userId);
            allow update: if isAdmin() || isValidOwnUserUpdate(userId);
            allow delete: if isAdmin();
    }

    match /nicknames/{nicknameId} {
      allow get: if true;
      allow list: if false;
      allow create: if isValidNicknameReservation();
      allow update, delete: if isAdmin();
    }

    match /ads/{adId} {
      allow get, list: if isAdmin() ||
        (signedIn() && isSelf(resource.data.userId)) ||
        isPublicAdRead();
      allow create: if canUseAccount() &&
        isSelf(request.resource.data.userId) &&
        !hasProtectedAdCreateFields();
      allow update: if (
        (canUseAccount() && isSelf(resource.data.userId) && (!isProtectedAdFieldChanged() || isUserSoftDeletingAd())) ||
        isAdmin()
      );
      allow delete: if false;
    }

    match /auctions/{auctionId} {
      allow get, list: if isAdmin() ||
        (signedIn() && isSelf(resource.data.ownerId)) ||
        isPublicAuctionRead();
      allow create: if canUseAccount() &&
        isSelf(request.resource.data.ownerId) &&
        !hasPaidAuctionCreateFields();
      allow update: if (
        (canUseAccount() && isSelf(resource.data.ownerId) && (!isProtectedAuctionFieldChanged() || isUserSoftDeletingAuction())) ||
        isValidAuctionBidUpdate() ||
        isAdmin()
      );
      allow delete: if false;
    }

    match /auctionBids/{auctionId}/bids/{bidId} {
      allow read: if isAdmin() || (signedIn() && (
        isSelf(resource.data.userId) ||
        isSelf(get(/databases/$(database)/documents/auctions/$(auctionId)).data.ownerId)
      ));
      allow create: if canUseAccount() && isValidAuctionBidCreate(auctionId);
      allow update, delete: if false;
    }

    match /chats/{chatId} {
      allow read: if isAdmin() || (signedIn() && (
        authUid() in resource.data.users || authEmail() in resource.data.users
      ));
      allow update: if canUseAccount() && (
        authUid() in resource.data.users || authEmail() in resource.data.users
      );
      allow create: if canUseAccount() && (
        authUid() in request.resource.data.users || authEmail() in request.resource.data.users
      );

      match /messages/{messageId} {
        allow read: if signedIn() && (
          authUid() in get(/databases/$(database)/documents/chats/$(chatId)).data.users ||
          authEmail() in get(/databases/$(database)/documents/chats/$(chatId)).data.users
        );
        allow create: if canUseAccount() && (
          authUid() in get(/databases/$(database)/documents/chats/$(chatId)).data.users ||
          authEmail() in get(/databases/$(database)/documents/chats/$(chatId)).data.users
        );
        allow update, delete: if false;
      }
    }

    function isValidContentReportCreate() {
      return request.resource.data.keys().hasOnly([
        'targetType',
        'targetId',
        'reporterId',
        'reason',
        'description',
        'status',
        'createdAt',
        'reviewedAt',
        'reviewedBy'
      ]) &&
      request.resource.data.targetType in ['ad', 'auction'] &&
      request.resource.data.targetId is string &&
      request.resource.data.reporterId == authUid() &&
      request.resource.data.reason is string &&
      request.resource.data.description is string &&
      request.resource.data.status == 'new' &&
      request.resource.data.createdAt is number &&
      request.resource.data.reviewedAt == null &&
      request.resource.data.reviewedBy == null;
    }

    function isValidChatMessageReportCreate(reportId) {
      let chatPath = /databases/$(database)/documents/chats/$(request.resource.data.chatId);
      let messagePath = /databases/$(database)/documents/chats/$(request.resource.data.chatId)/messages/$(request.resource.data.messageId);
      return request.resource.data.keys().hasOnly([
        'type',
        'chatId',
        'messageId',
        'senderId',
        'senderName',
        'reportedBy',
        'reportedByName',
        'messageText',
        'reason',
        'description',
        'reasonType',
        'reasonText',
        'createdAt',
        'status'
      ]) &&
      request.resource.data.type == 'chat_message' &&
      request.resource.data.chatId is string &&
      request.resource.data.messageId is string &&
      request.resource.data.senderId is string &&
      request.resource.data.reportedBy == authUid() &&
      request.resource.data.senderId != authUid() &&
      request.resource.data.senderId != authEmail() &&
      request.resource.data.senderName is string &&
      request.resource.data.reportedByName is string &&
      request.resource.data.messageText is string &&
      request.resource.data.messageText.size() > 0 &&
      request.resource.data.messageText.size() <= 5000 &&
      request.resource.data.reason is string &&
      request.resource.data.reasonType in ['spam', 'scam', 'abuse', 'suspicious_link', 'other'] &&
      request.resource.data.reason == request.resource.data.reasonType &&
      request.resource.data.description is string &&
      request.resource.data.description.size() <= 1000 &&
      request.resource.data.reasonText is string &&
      request.resource.data.reasonText == request.resource.data.description &&
      request.resource.data.createdAt is number &&
      request.resource.data.status == 'pending' &&
      reportId == 'chat_message_' + request.resource.data.chatId + '_' + request.resource.data.messageId + '_' + authUid() &&
      exists(chatPath) &&
      exists(messagePath) &&
      (authUid() in get(chatPath).data.users || authEmail() in get(chatPath).data.users) &&
      get(messagePath).data.senderId == request.resource.data.senderId &&
      get(messagePath).data.senderType == 'user';
    }

    match /reports/{reportId} {
      allow create: if signedIn() && (
        isValidContentReportCreate() ||
        isValidChatMessageReportCreate(reportId)
      );
      allow read, update, delete: if isAdmin();
    }
match /userReviews/{reviewId} {
allow read: if true;
allow create: if signedIn() &&
    isSelf(request.resource.data.authorUserId) &&
    request.resource.data.targetUserId != request.resource.data.authorUserId &&
request.resource.data.karmaValue in [-1, 1] &&
(!("comment" in request.resource.data) || request.resource.data.comment is string);
allow update: if signedIn() && isSelf(resource.data.authorUserId) &&
    request.resource.data.authorUserId == resource.data.authorUserId &&
    request.resource.data.targetUserId == resource.data.targetUserId &&
request.resource.data.adId == resource.data.adId &&
request.resource.data.karmaValue in [-1, 1] &&
(!("comment" in request.resource.data) || request.resource.data.comment is string);
allow delete: if isAdmin();
}

    match /payments/{paymentId} {
      allow read: if signedIn() && (
        isSelf(resource.data.userId) ||
        isSelf(resource.data.userEmail) ||
         isSelf(resource.data.payerEmail) ||
        isAdmin()
      );
      allow create, update, delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow read, update, delete: if isAdmin();
      allow create: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
